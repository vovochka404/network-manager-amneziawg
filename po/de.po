#: properties/nm-amneziawg-editor-plugin.c:70
msgid "Unknown AmneziaWG file extension"
msgstr "Unbekannte AmneziaWG-Dateierweiterung"

#: properties/nm-amneziawg-editor-plugin.c:79
msgid "Failed to parse AmneziaWG config file"
msgstr "AmneziaWG-Konfigurationsdatei konnte nicht analysiert werden"

#: properties/nm-amneziawg-editor.c:272
msgid "H1-H4 magic header ranges must not overlap"
msgstr "H1-H4 Magic-Header-Bereiche dürfen sich nicht überschneiden"

#: properties/nm-amneziawg-editor.c:285
msgid "JMax must be greater than or equal to JMin"
msgstr "JMax muss größer oder gleich JMin sein"

#: properties/nm-amneziawg-editor.c:712
msgid "Public key is required and must be valid base64\n"
msgstr ""
"Öffentlicher Schlüssel ist erforderlich und muss gültiges Base64 sein\n"

#: properties/nm-amneziawg-editor.c:716
msgid "Endpoint is required and must be valid (host:port)"
msgstr "Endpunkt ist erforderlich und muss gültig sein (host:port)"

#: properties/nm-amneziawg-editor.c:721
msgid "Allowed IPs must be valid subnets (e.g., 10.0.0.0/24)"
msgstr "Erlaubte IPs müssen gültige Subnetze sein (z.B. 10.0.0.0/24)"

#: properties/nm-amneziawg-editor.c:727
msgid "Preshared key must be valid base64 or empty"
msgstr "Vorheriger Schlüssel muss gültiges Base64 oder leer sein"

#: properties/nm-amneziawg-editor.c:1047
#: properties/nm-amneziawg-editor.c:1060
#, c-format
msgid "Delete peer \"%s\"?"
msgstr "Peer \"%s\" löschen?"

#: properties/nm-amneziawg-editor.c:1232
msgid "Peer"
msgstr "Peer"

#: properties/nm-amneziawg-editor.c:1530
msgid "Could not create amneziawg object"
msgstr "AmneziaWG-Objekt konnte nicht erzeugt werden"

#: properties/nm-amneziawg-editor.c:1549
msgid "could not load UI widget"
msgstr "UI-Widget konnte nicht geladen werden"

#: src/nm-amneziawg-service.c:479
#: src/nm-amneziawg-service.c:480
msgid "Private key is required"
msgstr "Privater Schlüssel ist erforderlich"

#: shared/nm-utils/nm-shared-utils.c:615
#, c-format
msgid "object class '%s' has no property named '%s'"
msgstr "Objektklasse »%s« hat keine Eigenschaft namens »%s«"

#: shared/nm-utils/nm-shared-utils.c:622
#, c-format
msgid "property '%s' of object class '%s' is not writable"
msgstr "Eigenschaft »%s« der Objektklasse »%s« ist nicht schreibgeschützt"

#: shared/nm-utils/nm-shared-utils.c:629
#, c-format
msgid ""
"construct property \"%s\" for object '%s' can't be set after construction"
msgstr ""
"Konstruktor-Eigenschaft »%s« für Objekt »%s« kann nicht nach der "
"Konstruktion gesetzt werden"

#: shared/nm-utils/nm-shared-utils.c:637
#, c-format
msgid "'%s::%s' is not a valid property name; '%s' is not a GObject subtype"
msgstr ""
"»%s::%s« ist kein gültiger Eigenschaftsname; »%s« ist kein GObject-Subtyp"

#: shared/nm-utils/nm-shared-utils.c:646
#, c-format
msgid "unable to set property '%s' of type '%s' from value of type '%s'"
msgstr ""
"Eigenschaft »%s« des Typs »%s« kann nicht aus dem Wert des Typs »%s« gesetzt "
"werden"

#: shared/nm-utils/nm-shared-utils.c:656
#, c-format
msgid ""
"value \"%s\" of type '%s' is invalid or out of range for property '%s' of "
"type '%s'"
msgstr ""
"Wert »%s« des Typs »%s« ist ungültig oder außerhalb des zulässigen Bereichs "
"der Eigenschaft »%s« des Typs »%s«"

#: shared/nm-utils/nm-vpn-plugin-utils.c:80
#, c-format
msgid "missing plugin file \"%s\""
msgstr "Erweiterungs-Datei »%s« fehlt"

#: shared/nm-utils/nm-vpn-plugin-utils.c:86
#, c-format
msgid "cannot load editor plugin: %s"
msgstr "Editor-Erweiterung kann nicht geladen werden: %s"

#: shared/nm-utils/nm-vpn-plugin-utils.c:95
#, c-format
msgid "cannot load factory %s from plugin: %s"
msgstr "Factory %s kann nicht aus Erweiterung geladen werden: %s"

#: shared/nm-utils/nm-vpn-plugin-utils.c:121
msgid "unknown error creating editor instance"
msgstr "Unbekannter Fehler beim Erzeugen der Editor-Instanz"

#: properties/nm-amneziawg-dialog.ui:33
msgid "Edit AmneziaWG Peer"
msgstr "AmneziaWG-Peer bearbeiten"

#: properties/nm-amneziawg-dialog.ui:46
msgid "_Cancel"
msgstr "_Abbrechen"

#: properties/nm-amneziawg-dialog.ui:60
msgid "_Apply"
msgstr "_Anwenden"

#: properties/nm-amneziawg-dialog.ui:143
msgid "Public Key:"
msgstr "Öffentlicher Schlüssel:"

#: properties/nm-amneziawg-dialog.ui:154
msgid "Base64-encoded 32-byte public key of the peer."
msgstr "Base64-kodierter 32-Byte öffentlicher Schlüssel des Peers."

#: properties/nm-amneziawg-dialog.ui:167
msgid "Allowed IPs:"
msgstr "Erlaubte IPs:"

#: properties/nm-amneziawg-dialog.ui:178
msgid ""
"Comma-separated list of IP addresses and prefixes to route through the peer "
"(e.g., 10.0.0.0/24, 0.0.0.0/0 for all IPv4)."
msgstr ""
"Kommagetrennte Liste von IP-Adressen und Präfixen zur Weiterleitung durch "
"den Peer (z.B. 10.0.0.0/24, 0.0.0.0/0 für alles IPv4)."

#: properties/nm-amneziawg-dialog.ui:191
msgid "Endpoint:"
msgstr "Endpunkt:"

#: properties/nm-amneziawg-dialog.ui:202
msgid "Host:port of the peer endpoint (e.g., vpn.example.com:51820)."
msgstr "Host:Port des Peer-Endpunkts (z.B. vpn.example.com:51820)."

#: properties/nm-amneziawg-dialog.ui:215
msgid "Preshared Key:"
msgstr "Vorher geteilter Schlüssel:"

#: properties/nm-amneziawg-dialog.ui:226
msgid "Optional base64-encoded 32-byte preshared key for extra security."
msgstr ""
"Optionaler Base64-kodierter 32-Byte Vorschlüssel für zusätzliche Sicherheit."

#: properties/nm-amneziawg-dialog.ui:237
msgid "Show preshared key"
msgstr "Vorher geteilten Schlüssel anzeigen"

#: properties/nm-amneziawg-dialog.ui:254
msgid "Persistent Keepalive:"
msgstr "Persistant Keepalive:"

#: properties/nm-amneziawg-dialog.ui:265
msgid ""
"Seconds between persistent keepalive packets (0 = disabled, recommended 25)."
msgstr ""
"Sekunden zwischen persistent Keepalive-Paketen (0 = deaktiviert, empfohlen "
"25)."

#: properties/nm-amneziawg-dialog.ui:277
msgid "_Advanced Security"
msgstr "_Erweiterte Sicherheit"

#: properties/nm-amneziawg-dialog.ui:281
msgid ""
"Enable advanced security features for this peer (junk packets, headers, "
"etc.)."
msgstr ""
"Erweiterte Sicherheitsfunktionen für diesen Peer aktivieren (Junk-Pakete, "
"Header usw.)."

#: properties/nm-amneziawg-dialog.ui:357
msgid "Interface"
msgstr "Schnittstelle"

#: properties/nm-amneziawg-dialog.ui:377
msgid "Listen Port:"
msgstr "Listen-Port:"

#: properties/nm-amneziawg-dialog.ui:391
msgid "UDP port to listen on (0 = random port)."
msgstr "UDP-Port zum Lauschen (0 = zufälliger Port)."

#: properties/nm-amneziawg-dialog.ui:417
msgid "Private Key:"
msgstr "Privater Schlüssel:"

#: properties/nm-amneziawg-dialog.ui:431
msgid "Base64-encoded 32-byte private key for the interface."
msgstr "Base64-kodierter 32-Byte privater Schlüssel für die Schnittstelle."

#: properties/nm-amneziawg-dialog.ui:442
msgid "Show private key"
msgstr "Privaten Schlüssel anzeigen"

#: properties/nm-amneziawg-dialog.ui:475
msgid "MTU:"
msgstr "MTU:"

#: properties/nm-amneziawg-dialog.ui:489
msgid "MTU of the interface (0 = auto-detect, typical values 1280-1500)."
msgstr "MTU der Schnittstelle (0 = Auto-Erkennung, typische Werte 1280-1500)."

#: properties/nm-amneziawg-dialog.ui:515
msgid "FwMark:"
msgstr "FwMark:"

#: properties/nm-amneziawg-dialog.ui:529
msgid ""
"Firewall mark for the interface (optional, used for routing/firewall rules)."
msgstr ""
"Firewall-Markierung für die Schnittstelle (optional, verwendet für Routing/"
"Firewall-Regeln)."

#: properties/nm-amneziawg-dialog.ui:591
msgid "Jc:"
msgstr "Jc:"

#: properties/nm-amneziawg-dialog.ui:605
msgid "Junk packet count - number of random junk sizes to use."
msgstr "Junk-Paket-Anzahl - Anzahl der zufälligen Junk-Größen."

#: properties/nm-amneziawg-dialog.ui:636
msgid "JMax:"
msgstr "JMax:"

#: properties/nm-amneziawg-dialog.ui:650
msgid "Maximum junk packet size in bytes."
msgstr "Maximale Junk-Paket-Größe in Bytes."

#: properties/nm-amneziawg-dialog.ui:677
msgid "JMin:"
msgstr "JMin:"

#: properties/nm-amneziawg-dialog.ui:691
msgid "Minimum junk packet size in bytes."
msgstr "Minimale Junk-Paket-Größe in Bytes."

#: properties/nm-amneziawg-dialog.ui:722
msgid "Junk Packets"
msgstr "Junk-Pakete"

#: properties/nm-amneziawg-dialog.ui:761
msgid "S1:"
msgstr "S1:"

#: properties/nm-amneziawg-dialog.ui:775
msgid "First noise packet size."
msgstr "Erste Rausch-Paket-Größe."

#: properties/nm-amneziawg-dialog.ui:801
msgid "S2:"
msgstr "S2:"

#: properties/nm-amneziawg-dialog.ui:815
msgid "Second noise packet size."
msgstr "Zweite Rausch-Paket-Größe."

#: properties/nm-amneziawg-dialog.ui:841
msgid "S3:"
msgstr "S3:"

#: properties/nm-amneziawg-dialog.ui:855
msgid "Cookie reply packet junk size (max 65479)."
msgstr "Größe des Junk-Pakets für Cookie-Antworten (max. 65479)."

#: properties/nm-amneziawg-dialog.ui:881
msgid "S4:"
msgstr "S4:"

#: properties/nm-amneziawg-dialog.ui:895
msgid "Transport packet junk size (max 65503)."
msgstr "Größe des Junk-Pakets für Transportpakete (max. 65503)."

#: properties/nm-amneziawg-dialog.ui:918
#, fuzzy
msgid "Noise Packet Sizes"
msgstr "Erste Rausch-Paket-Größe."

#: properties/nm-amneziawg-dialog.ui:961
msgid "H1:"
msgstr "H1:"

#: properties/nm-amneziawg-dialog.ui:975
msgid ""
"First handshake packet magic header. Format: single number (e.g., 1) or "
"range (e.g., 100-200). H1-H4 ranges must not overlap."
msgstr ""
"Erster Handshake-Paket Magic-Header. Format: einzelne Zahl (z.B. 1) oder "
"Bereich (z.B. 100-200). H1-H4 Bereiche dürfen sich nicht überschneiden."

#: properties/nm-amneziawg-dialog.ui:1000
msgid "H2:"
msgstr "H2:"

#: properties/nm-amneziawg-dialog.ui:1014
msgid ""
"Second handshake packet magic header. Format: single number (e.g., 2) or "
"range (e.g., 100-200). H1-H4 ranges must not overlap."
msgstr ""
"Zweiter Handshake-Paket Magic-Header. Format: einzelne Zahl (z.B. 2) oder "
"Bereich (z.B. 100-200). H1-H4 Bereiche dürfen sich nicht überschneiden."

#: properties/nm-amneziawg-dialog.ui:1051
msgid "H3:"
msgstr "H3:"

#: properties/nm-amneziawg-dialog.ui:1065
msgid ""
"Third handshake packet magic header. Format: single number (e.g., 3) or "
"range (e.g., 100-200). H1-H4 ranges must not overlap."
msgstr ""
"Dritter Handshake-Paket Magic-Header. Format: einzelne Zahl (z.B. 3) oder "
"Bereich (z.B. 100-200). H1-H4 Bereiche dürfen sich nicht überschneiden."

#: properties/nm-amneziawg-dialog.ui:1090
msgid "H4:"
msgstr "H4:"

#: properties/nm-amneziawg-dialog.ui:1104
msgid ""
"Fourth handshake packet magic header. Format: single number (e.g., 4) or "
"range (e.g., 100-200). H1-H4 ranges must not overlap."
msgstr ""
"Vierter Handshake-Paket Magic-Header. Format: einzelne Zahl (z.B. 4) oder "
"Bereich (z.B. 100-200). H1-H4 Bereiche dürfen sich nicht überschneiden."

#: properties/nm-amneziawg-dialog.ui:1133
msgid "Magic Headers"
msgstr "Magic-Header"

#: properties/nm-amneziawg-dialog.ui:1172
msgid "I1:"
msgstr "I1:"

#: properties/nm-amneziawg-dialog.ui:1186
msgid ""
"First init packet content. Format: tags separated by < (e.g., r16, "
"b0xDEADBEEF, r16<c). Tags: r<num> (random bytes), rc<num> (random letters), "
"rd<num> (random digits), c (counter), t (timestamp), b0x<hex> (binary)."
msgstr ""
"Erster Init-Paket Inhalt. Format: Tags getrennt durch < (z.B. r16, "
"b0xDEADBEEF, r16<c). Tags: r<num> (zufällige Bytes), rc<num> (zufällige "
"Buchstaben), rd<num> (zufällige Ziffern), c (Zähler), t (Zeitstempel), "
"b0x<hex> (binär)."

#: properties/nm-amneziawg-dialog.ui:1210
msgid "I2:"
msgstr "I2:"

