#: nm-amneziawg-dialog.ui:172
msgid "Base64-encoded 32-byte public key of the peer."
msgstr "Base64-kodierter 32-Byte öffentlicher Schlüssel des Peers."

#: nm-amneziawg-dialog.ui:195
msgid "Comma-separated list of IP addresses and prefixes to route through the peer (e.g., 10.0.0.0/24, 0.0.0.0/0 for all IPv4)."
msgstr "Kommagetrennte Liste von IP-Adressen und Präfixen zur Weiterleitung durch den Peer (z.B. 10.0.0.0/24, 0.0.0.0/0 für alles IPv4)."

#: nm-amneziawg-dialog.ui:218
msgid "Host:port of the peer endpoint (e.g., vpn.example.com:51820)."
msgstr "Host:Port des Peer-Endpunkts (z.B. vpn.example.com:51820)."

#: nm-amneziawg-dialog.ui:244
msgid "Optional base64-encoded 32-byte preshared key for extra security."
msgstr "Optionaler Base64-kodierter 32-Byte Vorschlüssel für zusätzliche Sicherheit."

#: nm-amneziawg-dialog.ui:284
msgid "Seconds between persistent keepalive packets (0 = disabled, recommended 25)."
msgstr "Sekunden zwischen persistent Keepalive-Paketen (0 = deaktiviert, empfohlen 25)."

#: nm-amneziawg-dialog.ui:396
msgid "UDP port to listen on (0 = random port)."
msgstr "UDP-Port zum Lauschen (0 = zufälliger Port)."

#: nm-amneziawg-dialog.ui:434
msgid "Base64-encoded 32-byte private key for the interface."
msgstr "Base64-kodierter 32-Byte privater Schlüssel für die Schnittstelle."

#: nm-amneziawg-dialog.ui:490
msgid "MTU of the interface (0 = auto-detect, typical values 1280-1500)."
msgstr "MTU der Schnittstelle (0 = Auto-Erkennung, typische Werte 1280-1500)."

#: nm-amneziawg-dialog.ui:531
msgid "Firewall mark for the interface (optional, used for routing/firewall rules)."
msgstr "Firewall-Markierung für die Schnittstelle (optional, verwendet für Routing/Firewall-Regeln)."

#: nm-amneziawg-dialog.ui:573
msgid "Junk packet count - number of random junk sizes to use."
msgstr "Junk-Paket-Anzahl - Anzahl der zufälligen Junk-Größen."

#: nm-amneziawg-dialog.ui:615
msgid "Minimum junk packet size in bytes."
msgstr "Minimale Junk-Paket-Größe in Bytes."

#: nm-amneziawg-dialog.ui:657
msgid "Maximum junk packet size in bytes."
msgstr "Maximale Junk-Paket-Größe in Bytes."

#: nm-amneziawg-dialog.ui:699
msgid "First noise packet size."
msgstr "Erste Rausch-Paket-Größe."

#: nm-amneziawg-dialog.ui:741
msgid "Second noise packet size."
msgstr "Zweite Rausch-Paket-Größe."

#: nm-amneziawg-dialog.ui:783
msgid "First handshake packet magic header value."
msgstr "Magischer Header-Wert des ersten Handshake-Pakets."

#: nm-amneziawg-dialog.ui:825
msgid "Second handshake packet magic header value."
msgstr "Magischer Header-Wert des zweiten Handshake-Pakets."

#: nm-amneziawg-dialog.ui:867
msgid "Third handshake packet magic header value."
msgstr "Magischer Header-Wert des dritten Handshake-Pakets."

#: nm-amneziawg-dialog.ui:909
msgid "Fourth handshake packet magic header value."
msgstr "Magischer Header-Wert des vierten Handshake-Pakets."
