#: nm-amneziawg-editor-plugin.c:69
msgid "Unknown AmneziaWG file extension"
msgstr "Unbekannte AmneziaWG-Dateierweiterung"

#: nm-amneziawg-editor-plugin.c:78
msgid "Failed to parse AmneziaWG config file"
msgstr "AmneziaWG-Konfigurationsdatei konnte nicht analysiert werden"

#: nm-amneziawg-editor.c:501
msgid "Public key is required and must be valid base64\n"
msgstr ""
"Öffentlicher Schlüssel ist erforderlich und muss gültiges Base64 sein\n"

#: nm-amneziawg-editor.c:505
msgid "Endpoint is required and must be valid (host:port)"
msgstr "Endpunkt ist erforderlich und muss gültig sein (host:port)"

#: nm-amneziawg-editor.c:784
msgid "Peer"
msgstr "Peer"

#: nm-amneziawg-editor.c:1039
msgid "Could not create amneziawg object"
msgstr "AmneziaWG-Objekt konnte nicht erzeugt werden"

#: nm-amneziawg-editor.c:1058
msgid "could not load UI widget"
msgstr "UI-Widget konnte nicht geladen werden"

#: nm-shared-utils.c:615
#, c-format
msgid "object class '%s' has no property named '%s'"
msgstr "Objektklasse »%s« hat keine Eigenschaft namens »%s«"

#: nm-shared-utils.c:622
#, c-format
msgid "property '%s' of object class '%s' is not writable"
msgstr "Eigenschaft »%s« der Objektklasse »%s« ist nicht schreibgeschützt"

#: nm-shared-utils.c:629
#, c-format
msgid ""
"construct property \"%s\" for object '%s' can't be set after construction"
msgstr ""
"Konstruktor-Eigenschaft »%s« für Objekt »%s« kann nicht nach der "
"Konstruktion gesetzt werden"

#: nm-shared-utils.c:637
#, c-format
msgid "'%s::%s' is not a valid property name; '%s' is not a GObject subtype"
msgstr ""
"»%s::%s« ist kein gültiger Eigenschaftsname; »%s« ist kein GObject-Subtyp"

#: nm-shared-utils.c:646
#, c-format
msgid "unable to set property '%s' of type '%s' from value of type '%s'"
msgstr ""
"Eigenschaft »%s« des Typs »%s« kann nicht aus dem Wert des Typs »%s« gesetzt "
"werden"

#: nm-shared-utils.c:656
#, c-format
msgid ""
"value \"%s\" of type '%s' is invalid or out of range for property '%s' of "
"type '%s'"
msgstr ""
"Wert »%s« des Typs »%s« ist ungültig oder außerhalb des zulässigen Bereichs "
"der Eigenschaft »%s« des Typs »%s«"

#: nm-vpn-plugin-utils.c:80
#, c-format
msgid "missing plugin file \"%s\""
msgstr "Erweiterungs-Datei »%s« fehlt"

#: nm-vpn-plugin-utils.c:86
#, c-format
msgid "cannot load editor plugin: %s"
msgstr "Editor-Erweiterung kann nicht geladen werden: %s"

#: nm-vpn-plugin-utils.c:95
#, c-format
msgid "cannot load factory %s from plugin: %s"
msgstr "Factory %s kann nicht aus Erweiterung geladen werden: %s"

#: nm-vpn-plugin-utils.c:121
msgid "unknown error creating editor instance"
msgstr "Unbekannter Fehler beim Erzeugen der Editor-Instanz"

