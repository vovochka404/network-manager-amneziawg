#: properties/nm-amneziawg-editor-plugin.c:70
msgid "Unknown AmneziaWG file extension"
msgstr "Неизвестное расширение файла AmneziaWG"

#: properties/nm-amneziawg-editor-plugin.c:79
msgid "Failed to parse AmneziaWG config file"
msgstr "Не удалось разобрать файл конфигурации AmneziaWG"

#: properties/nm-amneziawg-editor.c:272
msgid "H1-H4 magic header ranges must not overlap"
msgstr "Диапазоны магических заголовков H1-H4 не должны перекрываться"

#: properties/nm-amneziawg-editor.c:285
msgid "JMax must be greater than or equal to JMin"
msgstr "JMax должен быть больше или равен JMin"

#: properties/nm-amneziawg-editor.c:725
msgid "Public key is required and must be valid base64\n"
msgstr "Открытый ключ обязателен и должен быть в формате base64\n"

#: properties/nm-amneziawg-editor.c:729
msgid "Endpoint is required and must be valid (host:port)"
msgstr "Адрес подключения обязательна и должна быть в формате (хост:порт)"

#: properties/nm-amneziawg-editor.c:734
msgid "Allowed IPs must be valid subnets (e.g., 10.0.0.0/24)"
msgstr "Allowed IPs должны быть допустимыми подсетями (например, 10.0.0.0/24)"

#: properties/nm-amneziawg-editor.c:740
msgid "Preshared key must be valid base64 or empty"
msgstr "Общий ключ должен быть в формате base64 или пустым"

#: properties/nm-amneziawg-editor.c:1060 properties/nm-amneziawg-editor.c:1073
#, c-format
msgid "Delete peer \"%s\"?"
msgstr "Удалить пир \"%s\"?"

#: properties/nm-amneziawg-editor.c:1245
msgid "Peer"
msgstr "Пир"

#: properties/nm-amneziawg-editor.c:1543
msgid "Could not create amneziawg object"
msgstr "Не удалось создать объект amneziawg"

#: properties/nm-amneziawg-editor.c:1562
msgid "could not load UI widget"
msgstr "Не удалось загрузить виджет интерфейса"

#: src/nm-amneziawg-service.c:479 src/nm-amneziawg-service.c:480
msgid "Private key is required"
msgstr "Требуется закрытый ключ"

#: shared/nm-utils/nm-shared-utils.c:615
#, c-format
msgid "object class '%s' has no property named '%s'"
msgstr "класс объекта '%s' не имеет свойства с именем '%s'"

#: shared/nm-utils/nm-shared-utils.c:622
#, c-format
msgid "property '%s' of object class '%s' is not writable"
msgstr "свойство '%s' класса объекта '%s' недоступно для записи"

#: shared/nm-utils/nm-shared-utils.c:629
#, c-format
msgid ""
"construct property \"%s\" for object '%s' can't be set after construction"
msgstr ""
"конструктивное свойство \"%s\" для объекта '%s' не может быть установлено "
"после конструирования"

#: shared/nm-utils/nm-shared-utils.c:637
#, c-format
msgid "'%s::%s' is not a valid property name; '%s' is not a GObject subtype"
msgstr ""
"'%s::%s' не является допустимым именем свойства; '%s' не является подтипом "
"GObject"

#: shared/nm-utils/nm-shared-utils.c:646
#, c-format
msgid "unable to set property '%s' of type '%s' from value of type '%s'"
msgstr "невозможно установить свойство '%s' типа '%s' из значения типа '%s'"

#: shared/nm-utils/nm-shared-utils.c:656
#, c-format
msgid ""
"value \"%s\" of type '%s' is invalid or out of range for property '%s' of "
"type '%s'"
msgstr ""
"значение \"%s\" типа '%s' недопустимо или выходит за диапазон для свойства "
"'%s' типа '%s'"

#: shared/nm-utils/nm-vpn-plugin-utils.c:80
#, c-format
msgid "missing plugin file \"%s\""
msgstr "отсутствует файл плагина \"%s\""

#: shared/nm-utils/nm-vpn-plugin-utils.c:86
#, c-format
msgid "cannot load editor plugin: %s"
msgstr "не удалось загрузить плагин редактора: %s"

#: shared/nm-utils/nm-vpn-plugin-utils.c:95
#, c-format
msgid "cannot load factory %s from plugin: %s"
msgstr "не удалось загрузить фабрику %s из плагина: %s"

#: shared/nm-utils/nm-vpn-plugin-utils.c:121
msgid "unknown error creating editor instance"
msgstr "неизвестная ошибка при создании экземпляра редактора"

#: properties/nm-amneziawg-dialog.ui:33
msgid "Edit AmneziaWG Peer"
msgstr "Редактировать пир AmneziaWG"

#: properties/nm-amneziawg-dialog.ui:46
msgid "_Cancel"
msgstr "_Отмена"

#: properties/nm-amneziawg-dialog.ui:60
msgid "_Apply"
msgstr "_Применить"

#: properties/nm-amneziawg-dialog.ui:143
msgid "Public Key:"
msgstr "Открытый ключ:"

#: properties/nm-amneziawg-dialog.ui:154
msgid "Base64-encoded 32-byte public key of the peer."
msgstr "Открытый ключ пира в формате base64 (32 байта)."

#: properties/nm-amneziawg-dialog.ui:167
msgid "Allowed IPs:"
msgstr "Разрешённые IP:"

#: properties/nm-amneziawg-dialog.ui:178
msgid ""
"Comma-separated list of IP addresses and prefixes to route through the peer "
"(e.g., 10.0.0.0/24, 0.0.0.0/0 for all IPv4)."
msgstr ""
"Список IP-адресов и префиксов для маршрутизации через пир, разделенных "
"запятыми (например, 10.0.0.0/24, 0.0.0.0/0 для всего IPv4)."

#: properties/nm-amneziawg-dialog.ui:191
msgid "Endpoint:"
msgstr "Конечная точка:"

#: properties/nm-amneziawg-dialog.ui:202
msgid "Host:port of the peer endpoint (e.g., vpn.example.com:51820)."
msgstr "Адрес и порт пира (например, vpn.example.com:51820)."

#: properties/nm-amneziawg-dialog.ui:215
msgid "Preshared Key:"
msgstr "Общий ключ:"

#: properties/nm-amneziawg-dialog.ui:226
msgid "Optional base64-encoded 32-byte preshared key for extra security."
msgstr ""
"Необязательный общий ключ в формате base64 (32 байта) для дополнительной "
"безопасности."

#: properties/nm-amneziawg-dialog.ui:237
msgid "Show preshared key"
msgstr "Показать общий ключ"

#: properties/nm-amneziawg-dialog.ui:254
msgid "Persistent Keepalive:"
msgstr "Постоянный Keepalive:"

#: properties/nm-amneziawg-dialog.ui:265
msgid ""
"Seconds between persistent keepalive packets (0 = disabled, recommended 25)."
msgstr ""
"Интервал в секундах между пакетами keepalive (0 = выключено, рекомендуется "
"25)."

#: properties/nm-amneziawg-dialog.ui:277
msgid "_Advanced Security"
msgstr "_Расширенная безопасность"

#: properties/nm-amneziawg-dialog.ui:281
msgid ""
"Enable advanced security features for this peer (junk packets, headers, "
"etc.)."
msgstr ""
"Включить расширенные функции безопасности для этого пира (мусорные пакеты, "
"заголовки и т.д.)."

#: properties/nm-amneziawg-dialog.ui:357
msgid "Interface"
msgstr "Интерфейс"

#: properties/nm-amneziawg-dialog.ui:377
msgid "Private Key:"
msgstr "Закрытый ключ:"

#: properties/nm-amneziawg-dialog.ui:391
msgid "Base64-encoded 32-byte private key for the interface."
msgstr "Закрытый ключ интерфейса в формате base64 (32 байта)."

#: properties/nm-amneziawg-dialog.ui:402
msgid "Show private key"
msgstr "Показать закрытый ключ"

#: properties/nm-amneziawg-dialog.ui:430
msgid "Listen Port:"
msgstr "Порт прослушивания:"

#: properties/nm-amneziawg-dialog.ui:444
msgid "UDP port to listen on (0 = random port)."
msgstr "UDP-порт для прослушивания (0 = случайный порт)."

#: properties/nm-amneziawg-dialog.ui:475
msgid "MTU:"
msgstr "MTU:"

#: properties/nm-amneziawg-dialog.ui:489
msgid "MTU of the interface (0 = auto-detect, typical values 1280-1500)."
msgstr "MTU интерфейса (0 = автоопределение, типичные значения 1280-1500)."

#: properties/nm-amneziawg-dialog.ui:515
msgid "FwMark:"
msgstr "FwMark:"

#: properties/nm-amneziawg-dialog.ui:529
msgid ""
"Firewall mark for the interface (optional, used for routing/firewall rules)."
msgstr ""
"Метка фаервола для интерфейса (необязательно, используется для правил "
"маршрутизации/фаервола)."

#: properties/nm-amneziawg-dialog.ui:591
msgid "Jc:"
msgstr "Jc:"

#: properties/nm-amneziawg-dialog.ui:605
msgid "Junk packet count - number of random junk sizes to use."
msgstr "Количество мусорных пакетов - количество случайных размеров мусора."

#: properties/nm-amneziawg-dialog.ui:636
msgid "JMax:"
msgstr "JMax:"

#: properties/nm-amneziawg-dialog.ui:650
msgid "Maximum junk packet size in bytes."
msgstr "Максимальный размер мусорного пакета в байтах."

#: properties/nm-amneziawg-dialog.ui:677
msgid "JMin:"
msgstr "JMin:"

#: properties/nm-amneziawg-dialog.ui:691
msgid "Minimum junk packet size in bytes."
msgstr "Минимальный размер мусорного пакета в байтах."

#: properties/nm-amneziawg-dialog.ui:722
msgid "Junk Packets"
msgstr "Мусорные пакеты"

#: properties/nm-amneziawg-dialog.ui:761
msgid "S1:"
msgstr "S1:"

#: properties/nm-amneziawg-dialog.ui:775
msgid "First noise packet size."
msgstr "Размер первого шумового пакета."

#: properties/nm-amneziawg-dialog.ui:801
msgid "S2:"
msgstr "S2:"

#: properties/nm-amneziawg-dialog.ui:815
msgid "Second noise packet size."
msgstr "Размер второго шумового пакета."

#: properties/nm-amneziawg-dialog.ui:841
msgid "S3:"
msgstr "S3:"

#: properties/nm-amneziawg-dialog.ui:855
msgid "Cookie reply packet junk size (max 65479)."
msgstr "Размер мусора в пакете cookie-ответа (макс. 65479)."

#: properties/nm-amneziawg-dialog.ui:881
msgid "S4:"
msgstr "S4:"

#: properties/nm-amneziawg-dialog.ui:895
msgid "Transport packet junk size (max 65503)."
msgstr "Размер мусора в транспортном пакете (макс. 65503)."

#: properties/nm-amneziawg-dialog.ui:918
#, fuzzy
msgid "Noise Packet Sizes"
msgstr "Размер первого шумового пакета."

#: properties/nm-amneziawg-dialog.ui:961
msgid "H1:"
msgstr "H1:"

#: properties/nm-amneziawg-dialog.ui:975
msgid ""
"First handshake packet magic header. Format: single number (e.g., 1) or "
"range (e.g., 100-200). H1-H4 ranges must not overlap."
msgstr ""
"Магический заголовок первого пакета рукопожатия. Формат: одиночное число "
"(например, 1) или диапазон (например, 100-200). Диапазоны H1-H4 не должны "
"перекрываться."

#: properties/nm-amneziawg-dialog.ui:1000
msgid "H2:"
msgstr "H2:"

#: properties/nm-amneziawg-dialog.ui:1014
msgid ""
"Second handshake packet magic header. Format: single number (e.g., 2) or "
"range (e.g., 100-200). H1-H4 ranges must not overlap."
msgstr ""
"Магический заголовок второго пакета рукопожатия. Формат: одиночное число "
"(например, 2) или диапазон (например, 100-200). Диапазоны H1-H4 не должны "
"перекрываться."

#: properties/nm-amneziawg-dialog.ui:1051
msgid "H3:"
msgstr "H3:"

#: properties/nm-amneziawg-dialog.ui:1065
msgid ""
"Third handshake packet magic header. Format: single number (e.g., 3) or "
"range (e.g., 100-200). H1-H4 ranges must not overlap."
msgstr ""
"Магический заголовок третьего пакета рукопожатия. Формат: одиночное число "
"(например, 3) или диапазон (например, 100-200). Диапазоны H1-H4 не должны "
"перекрываться."

#: properties/nm-amneziawg-dialog.ui:1090
msgid "H4:"
msgstr "H4:"

#: properties/nm-amneziawg-dialog.ui:1104
msgid ""
"Fourth handshake packet magic header. Format: single number (e.g., 4) or "
"range (e.g., 100-200). H1-H4 ranges must not overlap."
msgstr ""
"Магический заголовок четвертого пакета рукопожатия. Формат: одиночное число "
"(например, 4) или диапазон (например, 100-200). Диапазоны H1-H4 не должны "
"перекрываться."

#: properties/nm-amneziawg-dialog.ui:1133
msgid "Magic Headers"
msgstr "Магические заголовки"

#: properties/nm-amneziawg-dialog.ui:1170
msgid "I1:"
msgstr "I1:"

#: properties/nm-amneziawg-dialog.ui:1184
msgid ""
"First init packet content (CPS format). Tags: &lt;r N&gt; (random bytes), "
"&lt;rc N&gt; (random ASCII), &lt;rd N&gt; (random digits), &lt;c&gt; "
"(counter), &lt;t&gt; (timestamp), &lt;b 0xHEX&gt; (static bytes). Example: "
"&lt;r 16&gt;&lt;c&gt;&lt;t&gt;&lt;b 0xDEADBEEF&gt;"
msgstr ""

#: properties/nm-amneziawg-dialog.ui:1209
msgid "I2:"
msgstr "I2:"

#: properties/nm-amneziawg-dialog.ui:1223
msgid ""
"Second init packet content (CPS format). Tags: &lt;r N&gt; (random bytes), "
"&lt;rc N&gt; (random ASCII), &lt;rd N&gt; (random digits), &lt;c&gt; "
"(counter), &lt;t&gt; (timestamp), &lt;b 0xHEX&gt; (static bytes). Example: "
"&lt;rc 10&gt;&lt;t&gt;"
msgstr ""

#: properties/nm-amneziawg-dialog.ui:1248
msgid "I3:"
msgstr "I3:"

#: properties/nm-amneziawg-dialog.ui:1262
msgid ""
"Third init packet content (CPS format). Tags: &lt;r N&gt; (random bytes), "
"&lt;rc N&gt; (random ASCII), &lt;rd N&gt; (random digits), &lt;c&gt; "
"(counter), &lt;t&gt; (timestamp), &lt;b 0xHEX&gt; (static bytes). Example: "
"&lt;b 0xDEADBEEF&gt;"
msgstr ""

#: properties/nm-amneziawg-dialog.ui:1287
msgid "I4:"
msgstr "I4:"

#: properties/nm-amneziawg-dialog.ui:1301
msgid ""
"Fourth init packet content (CPS format). Tags: &lt;r N&gt; (random bytes), "
"&lt;rc N&gt; (random ASCII), &lt;rd N&gt; (random digits), &lt;c&gt; "
"(counter), &lt;t&gt; (timestamp), &lt;b 0xHEX&gt; (static bytes). Example: "
"&lt;r 16&gt;&lt;t&gt;"
msgstr ""

#: properties/nm-amneziawg-dialog.ui:1326
msgid "I5:"
msgstr "I5:"

#: properties/nm-amneziawg-dialog.ui:1340
msgid ""
"Fifth init packet content (CPS format). Tags: &lt;r N&gt; (random bytes), "
"&lt;rc N&gt; (random ASCII), &lt;rd N&gt; (random digits), &lt;c&gt; "
"(counter), &lt;t&gt; (timestamp), &lt;b 0xHEX&gt; (static bytes). Example: "
"&lt;b 0xAABBCCDD&gt;&lt;rc 5&gt;&lt;rd 3&gt;&lt;c&gt;"
msgstr ""

#: properties/nm-amneziawg-dialog.ui:1362
msgid "Init Packet Content"
msgstr "Содержимое init-пакета"

#: properties/nm-amneziawg-dialog.ui:1381
msgid "AmneziaWG Obfuscation"
msgstr "Обфускация AmneziaWG"

#: properties/nm-amneziawg-dialog.ui:1411
msgid "Peers"
msgstr "Пиры"

#: properties/nm-amneziawg-dialog.ui:1430
msgid "Add"
msgstr "Добавить"

#: properties/nm-amneziawg-dialog.ui:1443
msgid "Edit"
msgstr "Редактировать"

